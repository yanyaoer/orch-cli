{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orch.result/reviewer/v1",
  "type": "object",
  "required": ["schema", "run_id", "verdict", "reviews_run_id", "blocking_findings", "non_blocking_findings", "suggested_tests"],
  "properties": {
    "schema": { "const": "orch.result/reviewer/v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "verdict": { "enum": ["approve", "request_changes"] },
    "reviews_run_id": { "type": "string" },
    "blocking_findings": { "type": "array" },
    "non_blocking_findings": { "type": "array" },
    "suggested_tests": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}

